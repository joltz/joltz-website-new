# Copy this file to server/.env and fill in your real values.
# Never commit the real .env file — it holds live secret keys.

# Stripe test-mode keys (from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# From `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# (Stripe CLI) during local dev, or from the webhook's settings page once
# it's registered against your deployed URL.
STRIPE_WEBHOOK_SECRET=whsec_...

# Server port
PORT=3000

# Bootstraps ONE admin account the first time the server ever runs (only
# used when the users table is empty). After that, manage admin access from
# the admin panel's Users tab — these three vars are ignored once any user
# exists, so it's safe to leave them in place.
ADMIN_NAME=Admin
ADMIN_EMAIL=you@joltz.club
ADMIN_PASSWORD=change-me-to-something-long-and-random

# Optional: override where the SQLite file lives
# DB_PATH=./server/data.db

# ---------------------------------------------------------------------------
# Only needed if the front-end is hosted somewhere other than this server —
# e.g. the static site on AWS Amplify Hosting, calling this API on a
# separate EC2/Lightsail host. Leave all three commented out for a normal
# same-origin deployment (e.g. `npm run server` serving both).
# ---------------------------------------------------------------------------

# Set to "production" when deployed for real — enables the Secure cookie
# flag (cookies require HTTPS) and general production behavior.
# NODE_ENV=production

# Exact origin(s) of your front-end, comma-separated, no trailing slash.
# Must match exactly what the browser sends as the Origin header.
# ALLOWED_ORIGINS=https://main.d1a2b3c4d5.amplifyapp.com,https://joltz.club

# Required whenever ALLOWED_ORIGINS is set. Switches the session cookie to
# SameSite=None; Secure, which browsers REQUIRE for cross-site cookies —
# and Secure means this API must be served over HTTPS, or logins will
# silently fail to persist (the browser rejects the cookie, no error shown).
# CROSS_ORIGIN_COOKIES=true

